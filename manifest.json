{
  "manifest_version": 3,
  "name": "WebClass Drop — ドラッグ＆ドロップ提出",
  "version": "1.1.2",
  "description": "WebClass のレポート提出などでファイルをドラッグ＆ドロップできるようにします。",
  "permissions": ["storage"],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WebClass Drop",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/webclass/*",
        "*://*/*/webclass/*",
        "*://*/WebClass/*",
        "*://*/*/WebClass/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
